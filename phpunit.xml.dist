<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="tests/bootstrap.php" colors="true" failOnWarning="true">
  <testsuites>
    <!-- "unit" excludes I18nCompletenessTest so it runs only once (in the dedicated i18n job). -->
    <testsuite name="unit">
      <directory>tests/unit</directory>
      <exclude>tests/unit/I18nCompletenessTest.php</exclude>
    </testsuite>
    <!-- "i18n" testsuite — run separately, on a single PHP version. -->
    <testsuite name="i18n">
      <file>tests/unit/I18nCompletenessTest.php</file>
    </testsuite>
  </testsuites>
  <source>
    <include>
      <directory suffix=".php">includes</directory>
    </include>
  </source>
</phpunit>
